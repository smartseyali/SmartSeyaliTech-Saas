# ── DATABASE PROVIDER ──
# Options: "supabase" | "postgres" | "api"
VITE_DB_PROVIDER=supabase

# ── SUPABASE (when VITE_DB_PROVIDER=supabase) ──
VITE_SUPABASE_URL=https://supabase.smartseyali.tech
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── CUSTOM API (when VITE_DB_PROVIDER=api) ──
VITE_API_URL=http://localhost:3000/api

# ── PLATFORM ──
VITE_SUPER_ADMIN_EMAIL=admin@smartseyali.com
