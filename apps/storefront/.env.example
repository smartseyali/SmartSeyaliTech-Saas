# ─────────────────────────────────────────────────────────────
# Storefront — set per-tenant at build time, NOT runtime
# ─────────────────────────────────────────────────────────────

# Which tenant this build is for (slug, lower-case)
TENANT_SLUG=pattikadai

# Base URL the build will be deployed to (subdomain default)
NEXT_PUBLIC_SITE_URL=https://pattikadai.smartseyali.com

# If tenant has a custom domain, set this and we use it as canonical
# NEXT_PUBLIC_PRIMARY_DOMAIN=https://pattikadai.com

# Per-tenant analytics IDs (configured in their hPanel / settings)
NEXT_PUBLIC_GTM_ID=GTM-58XDZQF4
# NEXT_PUBLIC_META_PIXEL_ID=
# NEXT_PUBLIC_GOOGLE_ADS_ID=

# Search Console verification (per tenant)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ─────────────────────────────────────────────────────────────
# Supabase — Phase 6 build-time product fetch (server-only, never sent to browser)
# Use service role key for full read access, or anon key if RLS allows public reads
# ─────────────────────────────────────────────────────────────
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Phase 4 — client-side live price/stock hydration (safe to expose to browser)
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Web3Forms (contact form — no server needed, static-export compatible)
# NEXT_PUBLIC_WEB3FORMS_KEY=

# ─────────────────────────────────────────────────────────────
# Phase 5 — Checkout & Payments
# ─────────────────────────────────────────────────────────────
# Supabase company_id for this tenant (integer from companies table)
# NEXT_PUBLIC_COMPANY_ID=

# Order number prefix (e.g. PATTI → PATTI-XYZ123)
# NEXT_PUBLIC_ORDER_PREFIX=PATTI

# Razorpay publishable key (rzp_live_... or rzp_test_...)
# NEXT_PUBLIC_RAZORPAY_KEY_ID=
